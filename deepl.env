ATJ_IGNORE_PREFIX="@@"
ATJ_START_DELIMITER="{{"
ATJ_END_DELIMITER="}}"
ATJ_MODE=file
ATJ_SOURCE_LOCALE=en
ATJ_KEEP_TRANSLATIONS=keep
ATJ_KEEP_EXTRA_TRANSLATIONS=remove
# Use either Pro or Free API key (not both)
ATJ_DEEPL_PRO_SECRET_KEY=your_deepl_pro_api_key_here
# ATJ_DEEPL_FREE_SECRET_KEY=your_deepl_free_api_key_here