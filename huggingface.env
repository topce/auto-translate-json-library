ATJ_IGNORE_PREFIX="@@"
ATJ_START_DELIMITER="{{"
ATJ_END_DELIMITER="}}"
ATJ_MODE=file
ATJ_SOURCE_LOCALE=en
ATJ_KEEP_TRANSLATIONS=keep
ATJ_KEEP_EXTRA_TRANSLATIONS=remove
# Hugging Face cloud mode - requires a free HF access token
# Get your token at: https://huggingface.co/settings/tokens
ATJ_HUGGING_FACE_API_KEY=hf_
# Optional explicit provider when HF auto-selection does not resolve one
ATJ_HUGGING_FACE_PROVIDER=hf-inference
# Use a translation model
ATJ_HUGGING_FACE_MODEL=Helsinki-NLP/opus-mt-en-fr
